/dts-v1/;

#include <espressif/esp32s3/esp32s3_mini_n8.dtsi>
#include "m5stack_atoms3-pinctrl.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "M5Stack AtomS3";
	compatible = "m5stack,atoms3";

	chosen {
		zephyr,sram    = &sram0;
		zephyr,flash   = &flash0;
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
		zephyr,display = &gc9107;
	};

	aliases {
		sw0        = &btn_a;
		watchdog0  = &wdt0;
		pwm-tone   = &pwm_tone;
		pwm-bl     = &pwm_bl;
		grove-nfc  = &grove_nfc;
	};

	/* ── Button ─────────────────────────────────────────────────────── */
	buttons {
		compatible = "gpio-keys";
		btn_a: button_a {
			gpios = <&gpio0 41 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Button A";
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	/* ── PWM nodes ──────────────────────────────────────────────────── */
	/*  Channel 0 → backlight (GPIO16)                                   */
	pwm_bl: pwm-backlight {
		compatible = "pwm-leds";
		pwm_bl_ch: pwm_bl_ch {
			pwms = <&ledc0 0 PWM_HZ(1000) PWM_POLARITY_NORMAL>;
			label = "Backlight";
		};
	};

	/*  Channel 1 → piezo/speaker tone (GPIO (choose free pin))         */
	pwm_tone: pwm-tone {
		compatible = "pwm-buzzer";
		pwms = <&ledc0 1 PWM_HZ(1000) PWM_POLARITY_NORMAL>;
		label = "Tone";
	};
};

/* ── USB CDC (virtual serial port) ─────────────────────────────────────── */
&usb_serial {
	status = "okay";
};

zephyr_udc0: &usb0 {
	status = "okay";
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};

/* ── I2C0: Grove PORT-A (SDA=GPIO2, SCL=GPIO1) ─────────────────────────── */
&i2c0 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;  /* 400 kHz */
	pinctrl-0 = <&i2c0_default>;
	pinctrl-names = "default";

	grove_nfc: grove_nfc@48 {
		compatible = "seeed,grove-nfc";
		reg = <0x48>;
		label = "GROVE_NFC";
		status = "okay";
	};
};

/* ── SPI2: GC9107 Display ───────────────────────────────────────────────── */
&spi2 {
	status = "okay";
	pinctrl-0 = <&spi2_default>;
	pinctrl-names = "default";
	cs-gpios = <&gpio0 15 GPIO_ACTIVE_LOW>;

	/* GC9107 is ST7789V-compatible in SPI mode */
	gc9107: gc9107@0 {
		compatible = "sitronix,st7789v";
		reg = <0>;
		spi-max-frequency = <DT_FREQ_M(40)>;
		cmd-data-gpios = <&gpio0 33 GPIO_ACTIVE_LOW>;
		reset-gpios    = <&gpio0 34 GPIO_ACTIVE_LOW>;
		width    = <128>;
		height   = <128>;
		x-offset = <2>;
		y-offset = <1>;
		/* GC9107 init values (tuned for AtomS3 panel) */
		vcom        = <0x19>;
		gctrl       = <0x35>;
		vrhs        = <0x12>;
		vdvs        = <0x20>;
		mdac        = <0x00>;
		gamma       = <0x01>;
		colmod      = <0x55>;    /* 16-bit RGB565 */
		lcm         = <0x2c>;
		porch-param = [0c 0c 00 33 33];
		cmd2en-param = [5a 69 02 01];
		pwctrl1-param = [a4 a1];
		pvgam-param = [D0 08 11 08 08 28 2E 48 41 2D 10 09 09 21 21];
		nvgam-param = [D0 08 10 08 06 06 39 44 51 0B 16 14 2F 31];
		ram-param   = [00 F8];
		rgb-param   = [CD 08 14];
	};
};

/* ── LEDC (PWM) ─────────────────────────────────────────────────────────── */
&ledc0 {
	status = "okay";
	pinctrl-0 = <&ledc0_default>;
	pinctrl-names = "default";
	#address-cells = <1>;
	#size-cells = <0>;

	/* Channel 0: display backlight (GPIO16) */
	channel0@0 {
		reg = <0x0>;
		timer = <0>;
	};

	/* Channel 1: speaker/buzzer tone (GPIO pin chosen at build time) */
	channel1@1 {
		reg = <0x1>;
		timer = <1>;
	};
};

/* ── Flash partitions (8 MB) ────────────────────────────────────────────── */
&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* Zephyr image (first 6 MB) */
		slot0_partition: partition@10000 {
			label = "image-0";
			reg = <0x00010000 0x5F0000>;
		};

		/* NVS settings storage (last 512 KB) */
		storage_partition: partition@780000 {
			label = "storage";
			reg = <0x00780000 0x80000>;
		};
	};
};
